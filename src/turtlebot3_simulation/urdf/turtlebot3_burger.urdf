<?xml version="1.0"?>
<robot name="turtlebot3_burger" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= MATERIALS ================= -->
  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
  <material name="dark_gray"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="light_gray"><color rgba="0.7 0.7 0.7 1.0"/></material>
  <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
  <material name="green"><color rgba="0.0 1.0 0.0 1.0"/></material>
  <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>

  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <!-- Inertial properties -->
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="1.0"/>
      <inertia ixx="0.004" ixy="0.0" ixz="0.0" iyy="0.004" iyz="0.0" izz="0.004"/>
    </inertial>
    
    <!-- Visual representation -->
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.132 0.140 0.072"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    
    <!-- Collision geometry -->
    <collision>
      <origin xyz="0.0 0.0 0.036" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.132 0.140 0.072"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= WHEELS ================= -->
  <!-- Left Wheel -->
  <link name="wheel_left_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.0 0.08 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit effort="0.5" velocity="10.0"/>
    <joint_properties damping="0.0" friction="0.0"/>
  </joint>

  <!-- Right Wheel -->
  <link name="wheel_right_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
    </collision>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.0 -0.08 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit effort="0.5" velocity="10.0"/>
    <joint_properties damping="0.0" friction="0.0"/>
  </joint>

  <!-- ================= CASTER WHEEL ================= -->
  <link name="caster_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
    
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
      <material name="black"/>
    </visual>
    
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
    </collision>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="0.05 0.0 -0.036" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- ================= LIDAR SENSOR ================= -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.125"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
    
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.095" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- ================= IMU SENSOR ================= -->
  <link name="imu_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
    
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.016 0.024 0.002"/>
      </geometry>
      <material name="green"/>
    </visual>
    
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.016 0.024 0.002"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.068" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- ================= GAZEBO PLUGINS ================= -->
  <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <command_topic>/cmd_vel</command_topic>
      <odometry_topic>/odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <publish_odometry>true</publish_odometry>
      <publish_odometry_tf>true</publish_odometry_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.16</wheel_separation>
      <wheel_diameter>0.066</wheel_diameter>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <max_wheel_torque>5.0</max_wheel_torque>
      
      <update_rate>30.0</update_rate>
    </plugin>
  </gazebo>

  <!-- LIDAR Gazebo Plugin -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>3.5</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
        <topic_name>/scan</topic_name>
        <frame_name>lidar_link</frame_name>
        <ros>
          <remapping>~/out:=/scan</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

  <!-- IMU Gazebo Plugin -->
  <gazebo reference="imu_link">
    <sensor type="imu" name="imu_sensor">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic_name>/imu</topic_name>
      <plugin name="gazebo_ros_imu" filename="libgazebo_ros_imu.so">
        <topic_name>/imu</topic_name>
        <frame_name>imu_link</frame_name>
        <ros>
          <remapping>~/out:=/imu</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ================= GAZEBO MATERIALS ================= -->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  
  <gazebo reference="wheel_left_link">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="wheel_right_link">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="lidar_link">
    <material>Gazebo/Red</material>
  </gazebo>
  
  <gazebo reference="imu_link">
    <material>Gazebo/Green</material>
  </gazebo>

</robot>
