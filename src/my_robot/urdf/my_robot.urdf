<?xml version="1.0"?>
<robot name="ece2318_robot">

  <!-- ================= COLORS ================= -->
  <material name="blue">   <color rgba="0 0.3 0.8 1"/> </material>
  <material name="black">  <color rgba="0.1 0.1 0.1 1"/> </material>
  <material name="gray">   <color rgba="0.5 0.5 0.5 1"/> </material>
  <material name="orange"> <color rgba="1.0 0.5 0.0 1"/> </material>

  <!-- ================= BASE (Increased Size) ================= -->
  <link name="base_link">
    <visual>
      <geometry> <box size="3.0 2.0 1.0"/> </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- ================= LIDAR ================= -->
  <link name="lidar_link">
    <visual>
      <geometry> <cylinder radius="0.25" length="0.5"/> </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- Placed on the front top of the base -->
    <origin xyz="1.3 0 0.75" rpy="0 0 0"/>
  </joint>

  <!-- ================= WHEELS ================= -->
  <!-- Front Left -->
  <link name="front_left_wheel">
    <visual>
      <geometry> <cylinder radius="0.6" length="0.4"/> </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="fl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="1.0 1.2 -0.5" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Front Right -->
  <link name="front_right_wheel">
    <visual>
      <geometry> <cylinder radius="0.6" length="0.4"/> </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="fr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="1.0 -1.2 -0.5" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Rear Left -->
  <link name="rear_left_wheel">
    <visual>
      <geometry> <cylinder radius="0.6" length="0.4"/> </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-1.0 1.2 -0.5" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Rear Right -->
  <link name="rear_right_wheel">
    <visual>
      <geometry> <cylinder radius="0.6" length="0.4"/> </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-1.0 -1.2 -0.5" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ================= ROBOTIC ARM ================= -->
  
  <!-- Arm Base Mount -->
  <link name="arm_base">
    <visual>
      <geometry> <cylinder radius="0.4" length="0.2"/> </geometry>
      <material name="gray"/>
    </visual>
  </link>
  <joint name="arm_base_joint" type="continuous">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0.0 0 0.6" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Arm Link 1 (Shoulder) -->
  <link name="arm_link_1">
    <visual>
      <!-- Shifted so it rotates from the bottom -->
      <origin xyz="0 0 0.8"/>
      <geometry> <box size="0.3 0.3 1.6"/> </geometry>
      <material name="orange"/>
    </visual>
  </link>
  <joint name="shoulder_joint" type="continuous">
    <parent link="arm_base"/>
    <child link="arm_link_1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Arm Link 2 (Elbow) -->
  <link name="arm_link_2">
    <visual>
      <!-- Shifted so it rotates from the bottom -->
      <origin xyz="0 0 0.6"/>
      <geometry> <box size="0.25 0.25 1.2"/> </geometry>
      <material name="orange"/>
    </visual>
  </link>
  <joint name="elbow_joint" type="continuous">
    <parent link="arm_link_1"/>
    <child link="arm_link_2"/>
    <origin xyz="0 0 1.6" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= END EFFECTOR (GRIPPER) ================= -->
  
  <!-- Gripper Base -->
  <link name="gripper_base">
    <visual>
      <geometry> <box size="0.5 0.2 0.2"/> </geometry>
      <material name="gray"/>
    </visual>
  </link>
  <joint name="wrist_joint" type="continuous">
    <parent link="arm_link_2"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 1.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Left Finger -->
  <link name="left_finger">
    <visual>
      <origin xyz="0 0 0.2"/>
      <geometry> <box size="0.1 0.1 0.4"/> </geometry>
      <material name="black"/>
    </visual>
  </link>
  <!-- Prismatic joint to open/close the finger -->
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0.2 0 0.1" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.1" effort="10" velocity="0.5"/>
  </joint>

  <!-- Right Finger -->
  <link name="right_finger">
    <visual>
      <origin xyz="0 0 0.2"/>
      <geometry> <box size="0.1 0.1 0.4"/> </geometry>
      <material name="black"/>
    </visual>
  </link>
  <!-- Prismatic joint to open/close the finger -->
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="-0.2 0 0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.1" effort="10" velocity="0.5"/>
  </joint>

</robot>