<?xml version="1.0"?>
<robot name="ece2318_robot">

  <!-- ================= COLORS ================= -->
  <material name="blue">   <color rgba="0.05 0.33 0.83 1"/> </material>
  <material name="black">  <color rgba="0.08 0.08 0.08 1"/> </material>
  <material name="gray">   <color rgba="0.55 0.55 0.55 1"/> </material>
  <material name="orange"> <color rgba="1.0 0.45 0.0 1"/>  </material>
  <material name="red">    <color rgba="0.85 0.1 0.1 1"/>  </material>
  <material name="white">  <color rgba="0.9 0.9 0.9 1"/>   </material>
  <material name="green">  <color rgba="0.1 0.75 0.2 1"/>  </material>
  <material name="yellow"> <color rgba="0.95 0.85 0.0 1"/> </material>

  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <visual>
      <geometry> <box size="3.0 2.0 0.9"/> </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry> <box size="3.0 2.0 0.9"/> </geometry>
    </collision>
    <inertial>
      <mass value="60.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="23.3" ixy="0" ixz="0" iyy="47.5" iyz="0" izz="66.7"/>
    </inertial>
  </link>

  <!-- ================= TOP PANEL (decorative) ================= -->
  <link name="top_panel">
    <visual>
      <geometry> <box size="2.8 1.8 0.05"/> </geometry>
      <material name="gray"/>
    </visual>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="1.0"/>
    </inertial>
  </link>
  <joint name="top_panel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_panel"/>
    <origin xyz="0 0 0.475" rpy="0 0 0"/>
  </joint>

  <!-- ================= LIDAR ================= -->
  <link name="lidar_link">
    <visual>
      <geometry> <cylinder radius="0.22" length="0.14"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.22" length="0.14"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.008"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="1.2 0 0.55" rpy="0 0 0"/>
  </joint>

  <!-- Lidar ring (visual detail) -->
  <link name="lidar_ring">
    <visual>
      <geometry> <cylinder radius="0.24" length="0.04"/> </geometry>
      <material name="gray"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="lidar_ring_joint" type="fixed">
    <parent link="lidar_link"/>
    <child link="lidar_ring"/>
    <origin xyz="0 0 -0.09" rpy="0 0 0"/>
  </joint>

  <!-- ================= CAMERA ================= -->
  <link name="camera_link">
    <visual>
      <geometry> <box size="0.12 0.32 0.1"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <box size="0.12 0.32 0.1"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="1.52 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- Camera lens (visual detail) -->
  <link name="camera_lens">
    <visual>
      <geometry> <cylinder radius="0.045" length="0.04"/> </geometry>
      <material name="white"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="camera_lens_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_lens"/>
    <origin xyz="0.08 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- ================= IMU ================= -->
  <link name="imu_link">
    <visual>
      <geometry> <box size="0.05 0.05 0.02"/> </geometry>
      <material name="green"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.46" rpy="0 0 0"/>
  </joint>

  <!-- ================= WHEELS ================= -->
  <!-- Front Left -->
  <link name="front_left_wheel">
    <visual>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.227" ixy="0" ixz="0" iyy="0.227" iyz="0" izz="0.454"/>
    </inertial>
  </link>
  <joint name="fl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="1.0 1.2 -0.45" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>

  <!-- Front Right -->
  <link name="front_right_wheel">
    <visual>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.227" ixy="0" ixz="0" iyy="0.227" iyz="0" izz="0.454"/>
    </inertial>
  </link>
  <joint name="fr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="1.0 -1.2 -0.45" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>

  <!-- Rear Left -->
  <link name="rear_left_wheel">
    <visual>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.227" ixy="0" ixz="0" iyy="0.227" iyz="0" izz="0.454"/>
    </inertial>
  </link>
  <joint name="rl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-1.0 1.2 -0.45" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>

  <!-- Rear Right -->
  <link name="rear_right_wheel">
    <visual>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.55" length="0.38"/> </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.227" ixy="0" ixz="0" iyy="0.227" iyz="0" izz="0.454"/>
    </inertial>
  </link>
  <joint name="rr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-1.0 -1.2 -0.45" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>

  <!-- ================= ROBOTIC ARM ================= -->

  <!-- Arm Base Turret (rotates 360°) -->
  <link name="arm_base">
    <visual>
      <geometry> <cylinder radius="0.36" length="0.22"/> </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.36" length="0.22"/> </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.06" ixy="0" ixz="0" iyy="0.06" iyz="0" izz="0.10"/>
    </inertial>
  </link>
  <joint name="arm_base_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0.0 0 0.56" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="50" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.5"/>
  </joint>

  <!-- Arm Link 1 (Shoulder/Upper Arm) -->
  <link name="arm_link_1">
    <visual>
      <origin xyz="0 0 0.8"/>
      <geometry> <box size="0.28 0.28 1.6"/> </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.8"/>
      <geometry> <box size="0.28 0.28 1.6"/> </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.8"/>
      <mass value="5.0"/>
      <inertia ixx="1.07" ixy="0" ixz="0" iyy="1.07" iyz="0" izz="0.052"/>
    </inertial>
  </link>
  <joint name="shoulder_joint" type="revolute">
    <parent link="arm_base"/>
    <child link="arm_link_1"/>
    <origin xyz="0 0 0.11" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="80" velocity="0.8"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>

  <!-- Arm Link 2 (Forearm/Elbow) -->
  <link name="arm_link_2">
    <visual>
      <origin xyz="0 0 0.6"/>
      <geometry> <box size="0.22 0.22 1.2"/> </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.6"/>
      <geometry> <box size="0.22 0.22 1.2"/> </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.6"/>
      <mass value="3.0"/>
      <inertia ixx="0.37" ixy="0" ixz="0" iyy="0.37" iyz="0" izz="0.024"/>
    </inertial>
  </link>
  <joint name="elbow_joint" type="revolute">
    <parent link="arm_link_1"/>
    <child link="arm_link_2"/>
    <origin xyz="0 0 1.6" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="0.0" effort="60" velocity="1.0"/>
    <dynamics damping="1.5" friction="0.8"/>
  </joint>

  <!-- ================= WRIST ================= -->
  <link name="wrist_link">
    <visual>
      <geometry> <cylinder radius="0.12" length="0.12"/> </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.12" length="0.12"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.008"/>
    </inertial>
  </link>
  <joint name="wrist_joint" type="revolute">
    <parent link="arm_link_2"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 1.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="30" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>

  <!-- ================= GRIPPER ================= -->
  <!-- Gripper Palm -->
  <link name="gripper_base">
    <visual>
      <geometry> <box size="0.45 0.18 0.12"/> </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry> <box size="0.45 0.18 0.12"/> </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.004"/>
    </inertial>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="wrist_link"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- Left Finger -->
  <link name="left_finger">
    <visual>
      <origin xyz="0 0 0.22"/>
      <geometry> <box size="0.09 0.09 0.44"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.22"/>
      <geometry> <box size="0.09 0.09 0.44"/> </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.22"/>
      <mass value="0.15"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0.18 0 0.06" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.18" effort="20" velocity="0.5"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <!-- Right Finger -->
  <link name="right_finger">
    <visual>
      <origin xyz="0 0 0.22"/>
      <geometry> <box size="0.09 0.09 0.44"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.22"/>
      <geometry> <box size="0.09 0.09 0.44"/> </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.22"/>
      <mass value="0.15"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="-0.18 0 0.06" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.18" effort="20" velocity="0.5"/>
    <dynamics damping="0.5" friction="0.2"/>
  </joint>

  <!-- Finger tip indicators (visual – shows closed/open state clearly) -->
  <link name="left_fingertip">
    <visual>
      <geometry> <sphere radius="0.05"/> </geometry>
      <material name="yellow"/>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="left_fingertip_joint" type="fixed">
    <parent link="left_finger"/>
    <child link="left_fingertip"/>
    <origin xyz="0 0 0.46" rpy="0 0 0"/>
  </joint>

  <link name="right_fingertip">
    <visual>
      <geometry> <sphere radius="0.05"/> </geometry>
      <material name="yellow"/>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  <joint name="right_fingertip_joint" type="fixed">
    <parent link="right_finger"/>
    <child link="right_fingertip"/>
    <origin xyz="0 0 0.46" rpy="0 0 0"/>
  </joint>

  <!-- ================= STATUS LED (visual indicator) ================= -->
  <link name="status_led">
    <visual>
      <geometry> <sphere radius="0.07"/> </geometry>
      <material name="green"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="status_led_joint" type="fixed">
    <parent link="base_link"/>
    <child link="status_led"/>
    <origin xyz="-1.3 0.0 0.5" rpy="0 0 0"/>
  </joint>

</robot>